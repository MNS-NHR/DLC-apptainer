BootStrap: docker
From: deeplabcut/deeplabcut:3.0.0-core-cuda12.4-cudnn9

%labels
        APPLICATION_NAME Deeplabcut in Apptainer with GUI 
        AUTHOR_NAME Joanes Grandjean
        YEAR 2026
        Version 20260317

%help
        This container is based on DLC docker image, with added dependencies to make the GUI work

%environment
        PATH=/bin:/sbin:/usr/bin:/usr/sbin:/usr/local/bin:/usr/local/sbin
        LANG=C.UTF-8 LC_ALL=C.UTF-8
        DLClight=False

%post

        apt-get -yy update

        apt-get install -yy --no-install-recommends curl libgtk-3-dev libsm6 libxext6 python3-wxgtk4.0 libxcb-xinerama0 libxcb-icccm4 libxcb-image0 libxcb-keysyms1 libxcb-randr0 libxcb-render-util0 libxcb-shape0 libxkbcommon-x11-0


# Install Deeplabcut gui
        python -m pip install deeplabcut[gui]
        
        #cd /opt/conda/lib/python3.11/site-packages/deeplabcut/pose_estimation_pytorch/models/backbones/pretrained_weights
        #curl http://download.tensorflow.org/models/resnet_v1_50_2016_08_28.tar.gz | tar xvz --no-same-owner
        #curl http://download.tensorflow.org/models/resnet_v1_101_2016_08_28.tar.gz | tar xvz --no-same-owner
        #curl http://download.tensorflow.org/models/resnet_v1_152_2016_08_28.tar.gz | tar xvz --no-same-owner
        #chmod -R 777 ./
        
# Cleanup
        apt-get -qq clean
        rm -rf /var/lib/apt/lists/* 

%runscript
        unset SESSION_MANAGER
        /opt/conda/bin/python3 -m deeplabcut
